rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user owns this document (uid matches)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Check if user is admin (custom claim)
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    
    // Validate that required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    // ==================== USER PROFILES ====================
    // Each user has a profile document: /users/{userId}
    match /users/{userId} {
      // Users can read/write their own profile
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasRequiredFields(['email', 'createdAt']);
      allow update: if isOwner(userId);
      allow delete: if false; // Prevent self-deletion, admin only
      
      // Admins can read any user profile
      allow read: if isAdmin();
    }
    
    // ==================== USER CONFIG ====================
    // Per-user configuration: /users/{userId}/config/{configId}
    match /users/{userId}/config/{configId} {
      allow read, write: if isOwner(userId);
    }

    // ==================== USER SECRETS ====================
    // Per-user provider passwords: /users/{userId}/secrets/{secretId}
    // Clients can WRITE (submit credentials) but NEVER READ them back.
    // Cloud Functions use the Admin SDK which bypasses these rules.
    match /users/{userId}/secrets/{secretId} {
      allow write: if isOwner(userId);
      allow read: if false; // Admin SDK only — prevents client-side credential exfiltration
    }
    
    // ==================== USER AUTOMATION STATE ====================
    // Per-user automation state: /users/{userId}/automation/{docId}
    match /users/{userId}/automation/{docId} {
      allow read, write: if isOwner(userId);
    }
    
    // ==================== USER AUTOMATION RULES ====================
    // Per-user automation rules: /users/{userId}/rules/{ruleId}
    match /users/{userId}/rules/{ruleId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && hasRequiredFields(['name', 'enabled', 'priority', 'createdAt']);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    // ==================== USER HISTORY ====================
    // Per-user automation history: /users/{userId}/history/{historyId}
    match /users/{userId}/history/{historyId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow delete: if isOwner(userId);
      // No updates to history (immutable log)
      allow update: if false;
    }

    // ==================== USER AUTOMATION AUDIT ====================
    // Per-user automation audit logs: /users/{userId}/automationAudit/{auditId}
    match /users/{userId}/automationAudit/{auditId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId); // Cloud Functions can also create via Admin SDK
      allow delete: if isOwner(userId);
      // No updates to audit logs (immutable log)
      allow update: if false;
    }

    // ==================== USER CACHE ====================
    // Per-user cache docs: /users/{userId}/cache/{cacheId}
    match /users/{userId}/cache/{cacheId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions can write (via Admin SDK)
    }

    // ==================== USER METRICS ====================
    // Per-user API counters: /users/{userId}/metrics/{metricId}
    match /users/{userId}/metrics/{metricId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions can write (via Admin SDK)
    }

    // ==================== QUICK CONTROL STATE ====================
    // Per-user quick-control override state: /users/{userId}/quickControl/{docId}
    match /users/{userId}/quickControl/{docId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions can write (via Admin SDK)
    }

    // ==================== CURTAILMENT STATE ====================
    // Per-user curtailment state: /users/{userId}/curtailment/{docId}
    match /users/{userId}/curtailment/{docId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Cloud Functions can write (via Admin SDK)
    }
    
    // ==================== SHARED CACHE (GLOBAL) - RESERVED ====================
    // NOTE: This collection is currently UNUSED. All caching is done per-user
    // at users/{userId}/cache/{cacheDoc}. This rule is preserved for potential
    // future use (e.g., shared rate-limit state, global announcements).
    // If implementing, ensure proper access controls.
    match /cache/{cacheId} {
      allow read: if false;  // Disabled - not currently used
      allow write: if false; // Only Cloud Functions can write (via Admin SDK)
    }
    
    // ==================== GLOBAL SETTINGS (ADMIN ONLY) ====================
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ==================== API METRICS (ADMIN ONLY) ====================
    match /metrics/{metricId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write
    }

    // ==================== ADMIN AUDIT LOGS ====================
    // Admin audit records: /admin_audit/{auditId}
    match /admin_audit/{auditId} {
      allow read: if isAdmin();
      allow write: if false; // Only Cloud Functions can write (via Admin SDK)
    }
    
    // ==================== NOTIFICATIONS ====================
    // Per-user notifications: /users/{userId}/notifications/{notificationId}
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow update: if isOwner(userId); // Mark as read
      allow delete: if isOwner(userId);
      allow create: if false; // Only Cloud Functions can create
    }

    // Per-user push subscription registry: /users/{userId}/pushSubscriptions/{subscriptionId}
    match /users/{userId}/pushSubscriptions/{subscriptionId} {
      allow read: if isOwner(userId);
      allow write: if false; // Cloud Functions only
    }

    // Per-user notification runtime state (dedupe/cooldown): /users/{userId}/notificationRuntime/{docId}
    match /users/{userId}/notificationRuntime/{docId} {
      allow read, write: if false; // Cloud Functions only
    }

    // Campaign/send history for admin notifications
    match /notificationCampaigns/{campaignId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ==================== SHARED SERVER CONFIG ====================
    // shared/serverConfig: non-sensitive config from unauthenticated setup (readable by authenticated users)
    // shared/serverCredentials: provider passwords — Cloud Functions (Admin SDK) only, never from client
    match /shared/serverCredentials {
      allow read: if false;  // Admin SDK only — passwords are never returned to any client
      allow write: if false; // Only Cloud Functions (Admin SDK) can write
    }
    match /shared/{docId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only Cloud Functions (Admin SDK) can write - NEVER from client
    }
  }
}
